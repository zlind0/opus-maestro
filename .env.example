# ── Required ──
OPENAI_API_KEY=sk-your-key-here
OPENAI_API_BASE=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Database
POSTGRES_USER=music
POSTGRES_PASSWORD=musicpass
POSTGRES_DB=music
DATABASE_URL=postgresql+asyncpg://music:musicpass@db:5432/music

# Security — change in production!
SECRET_KEY=change-me-to-a-random-string-at-least-32-chars

# Music library path (host path to mount)
MUSIC_PATH=/path/to/your/music

# ── Optional ──
LOG_LEVEL=info
AUDIO_CACHE_TTL=3600
DEFAULT_LANGUAGE=zh-CN
